{
  "consumer": {
    "name": "auth-hub"
  },
  "interactions": [
    {
      "description": "a ToSession request when rate limited",
      "providerStates": [
        {
          "name": "rate limit is exceeded"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "ory_kratos_session=any-token"
        },
        "method": "GET",
        "path": "/sessions/whoami"
      },
      "response": {
        "body": {
          "error": {
            "code": 429,
            "message": "API rate limit exceeded",
            "status": "Too Many Requests"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 429
      }
    },
    {
      "description": "a ToSession request with a valid session cookie",
      "providerStates": [
        {
          "name": "a valid session exists for user-001"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "ory_kratos_session=valid-session-token"
        },
        "method": "GET",
        "path": "/sessions/whoami"
      },
      "response": {
        "body": {
          "active": true,
          "id": "session-abc-123",
          "identity": {
            "created_at": "2026-01-01T00:00:00Z",
            "id": "user-001",
            "schema_id": "default",
            "schema_url": "http://kratos:4433/schemas/default",
            "traits": {
              "email": "user@example.com",
              "role": "user"
            }
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a ToSession request with an invalid session cookie",
      "providerStates": [
        {
          "name": "no valid session exists"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "ory_kratos_session=expired-token"
        },
        "method": "GET",
        "path": "/sessions/whoami"
      },
      "response": {
        "body": {
          "error": {
            "code": 401,
            "message": "No active session was found in this request",
            "status": "Unauthorized"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 401
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.4.2"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "kratos"
  }
}