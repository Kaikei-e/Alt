{
  "consumer": {
    "name": "recap-worker"
  },
  "interactions": [
    {
      "description": "a classification job submission",
      "providerStates": [
        {
          "name": "the classification model is loaded"
        }
      ],
      "request": {
        "body": {
          "texts": [
            "Article text to classify"
          ]
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.texts": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.texts[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.texts[*].*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/v1/classify-runs"
      },
      "response": {
        "body": {
          "job_id": "00000000-0000-0000-0000-000000000001",
          "result_count": 0,
          "run_id": 1,
          "status": "running"
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.job_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.result_count": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.run_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a clustering execution request",
      "providerStates": [
        {
          "name": "classified articles are ready for clustering"
        }
      ],
      "request": {
        "headers": {
          "content-type": "application/json"
        },
        "method": "POST",
        "path": "/v1/clustering/42"
      },
      "response": {
        "body": {
          "cluster_count": 3,
          "clusters": [
            {
              "cluster_id": 0,
              "representatives": [
                {
                  "sentence_text": "AI is transforming industries."
                }
              ],
              "size": 5,
              "top_terms": [
                "AI"
              ]
            }
          ],
          "genre": "technology",
          "job_id": "00000000-0000-0000-0000-000000000001",
          "run_id": 42,
          "status": "succeeded"
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.cluster_count": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.clusters": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.clusters[*].*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.clusters[*].cluster_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.clusters[*].representatives": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.clusters[*].representatives[*].*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.clusters[*].representatives[*].sentence_text": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.clusters[*].size": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.clusters[*].top_terms": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.clusters[*].top_terms[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.clusters[*].top_terms[*].*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.genre": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.job_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.run_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a coarse classification request",
      "providerStates": [
        {
          "name": "the classification model is loaded"
        }
      ],
      "request": {
        "body": {
          "text": "Breaking news about AI technology"
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.text": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/v1/classify/coarse"
      },
      "response": {
        "body": {
          "scores": {
            "science": 0.15,
            "technology": 0.8
          }
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.scores.science": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.scores.technology": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "polling a completed classification job",
      "providerStates": [
        {
          "name": "classification job 42 has succeeded"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/v1/classify-runs/42"
      },
      "response": {
        "body": {
          "job_id": "00000000-0000-0000-0000-000000000001",
          "result_count": 5,
          "results": [
            {
              "confidence": 0.85,
              "scores": {
                "science": 0.1,
                "technology": 0.85
              },
              "top_genre": "technology"
            }
          ],
          "run_id": 42,
          "status": "succeeded"
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.job_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.result_count": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.results[*].*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results[*].confidence": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results[*].scores.science": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results[*].scores.technology": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results[*].top_genre": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.run_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pactRust": {
      "consumer": "1.4.2",
      "mockserver": "2.1.3",
      "models": "1.3.8"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "recap-subworker"
  }
}