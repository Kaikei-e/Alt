{
  "consumer": {
    "name": "recap-worker"
  },
  "interactions": [
    {
      "description": "a batch tags request",
      "providerStates": [
        {
          "name": "tags exist for the requested articles"
        }
      ],
      "request": {
        "body": {
          "article_ids": [
            "art-001"
          ]
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.article_ids": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.article_ids[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.article_ids[*].*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/v1/tags/batch"
      },
      "response": {
        "body": {
          "success": true,
          "tags": {
            "art-001": [
              {
                "confidence": 0.95,
                "source": "classifier",
                "tag": "technology",
                "updated_at": "2026-03-26T00:00:00Z"
              }
            ]
          }
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.success": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.tags['art-001']": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.tags['art-001'][*].*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.tags['art-001'][*].confidence": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.tags['art-001'][*].source": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.tags['art-001'][*].tag": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.tags['art-001'][*].updated_at": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a tag extraction request",
      "providerStates": [
        {
          "name": "the tag extraction model is loaded"
        }
      ],
      "request": {
        "body": {
          "content": "Detailed article content about artificial intelligence.",
          "title": "AI Advances in 2026"
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.content": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/v1/extract-tags"
      },
      "response": {
        "body": {
          "confidence": 0.92,
          "success": true,
          "tags": [
            "artificial-intelligence"
          ]
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.confidence": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.success": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.tags": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.tags[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.tags[*].*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pactRust": {
      "consumer": "1.4.2",
      "mockserver": "2.1.3",
      "models": "1.3.8"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "tag-generator"
  }
}