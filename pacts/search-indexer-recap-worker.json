{
  "consumer": {
    "name": "search-indexer"
  },
  "interactions": [
    {
      "description": "a request for indexable recap genres",
      "providerStates": [
        {
          "name": "indexable recap genres exist"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/v1/recaps/genres/indexable",
        "query": {
          "limit": [
            "100"
          ]
        }
      },
      "response": {
        "body": {
          "has_more": false,
          "results": [
            {
              "bullets": [
                "AI continues to advance."
              ],
              "executed_at": "2026-03-26T00:00:00Z",
              "genre": "technology",
              "job_id": "job-001",
              "summary": "Weekly tech summary.",
              "tags": [
                "technology"
              ],
              "top_terms": [
                "AI"
              ],
              "window_days": 7
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.has_more": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.results[*].bullets": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.results[*].bullets[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results[*].executed_at": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results[*].genre": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results[*].job_id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results[*].summary": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results[*].tags": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.results[*].tags[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results[*].top_terms": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.results[*].top_terms[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.results[*].window_days": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.4.2"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "recap-worker"
  }
}