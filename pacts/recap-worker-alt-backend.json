{
  "consumer": {
    "name": "recap-worker"
  },
  "interactions": [
    {
      "description": "a paginated recap articles request",
      "providerStates": [
        {
          "name": "articles exist in the recap window"
        }
      ],
      "request": {
        "body": {
          "from": "2026-03-19T00:00:00Z",
          "page": 1,
          "pageSize": 500,
          "to": "2026-03-26T00:00:00Z"
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.from": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.page": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.pageSize": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.to": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/services.backend.v1.BackendInternalService/ListRecapArticles"
      },
      "response": {
        "body": {
          "articles": [
            {
              "articleId": "art-001",
              "fulltext": "Full article text content here.",
              "title": "Test Article Title"
            }
          ],
          "hasMore": false,
          "page": 1,
          "pageSize": 500,
          "range": {
            "from": "2026-03-19T00:00:00Z",
            "to": "2026-03-26T00:00:00Z"
          },
          "total": 42
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.articles": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.articles[*].*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articles[*].articleId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articles[*].fulltext": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articles[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.hasMore": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.page": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.pageSize": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.range.from": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.range.to": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.total": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a batch tags request by article ids",
      "providerStates": [
        {
          "name": "tags exist for the requested articles"
        }
      ],
      "request": {
        "body": {
          "articleIds": [
            "art-001"
          ]
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.articleIds": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.articleIds[*].*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/services.backend.v1.BackendInternalService/BatchGetTagsByArticleIDs"
      },
      "response": {
        "body": {
          "items": [
            {
              "articleId": "art-001",
              "tags": [
                {
                  "tagName": "technology",
                  "confidence": 0.95,
                  "source": "ml_model",
                  "updatedAt": "2026-03-26T00:00:00Z"
                }
              ]
            }
          ]
        },
        "headers": {
          "content-type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.items": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.items[*].articleId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].tags": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.items[*].tags[*].tagName": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].tags[*].confidence": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].tags[*].source": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].tags[*].updatedAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pactRust": {
      "consumer": "1.4.2",
      "mockserver": "2.1.3",
      "models": "1.3.8"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "alt-backend"
  }
}
