{
  "consumer": {
    "name": "search-indexer"
  },
  "interactions": [
    {
      "description": "a GetLatestArticleTimestamp request",
      "providerStates": [
        {
          "name": "articles exist in the database"
        }
      ],
      "request": {
        "body": {},
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/services.backend.v1.BackendInternalService/GetLatestArticleTimestamp"
      },
      "response": {
        "body": {
          "latestCreatedAt": "2026-03-26T00:00:00Z"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.latestCreatedAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a ListArticlesWithTags request for backward keyset pagination",
      "providerStates": [
        {
          "name": "articles with tags exist for backward pagination"
        }
      ],
      "request": {
        "body": {
          "lastId": "art-000",
          "limit": 200
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.lastId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.limit": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/services.backend.v1.BackendInternalService/ListArticlesWithTags"
      },
      "response": {
        "body": {
          "articles": [
            {
              "content": "Article content.",
              "createdAt": "2026-03-26T00:00:00Z",
              "feedId": "feed-001",
              "id": "art-001",
              "tags": [
                "technology"
              ],
              "title": "Test Article",
              "userId": "user-001"
            }
          ],
          "nextId": "art-002"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.articles": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.articles[*].content": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articles[*].createdAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articles[*].feedId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articles[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articles[*].tags": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.articles[*].tags[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articles[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articles[*].userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.nextId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.4.2"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "alt-backend"
  }
}