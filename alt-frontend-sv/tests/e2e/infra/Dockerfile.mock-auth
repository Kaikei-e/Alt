# Dockerfile for mock-auth server in development environment
# This runs the E2E mock server with JWT generation capabilities

FROM oven/bun:1.2-alpine

WORKDIR /app

# Install deps from bun.lock (reproducible; npm ci equivalent for this tree)
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

# Copy mock server and its dependencies
COPY tests/e2e/infra/mock-server.ts ./
COPY tests/e2e/infra/data/ ./data/
COPY tests/e2e/infra/handlers/ ./handlers/
COPY tests/e2e/infra/types/ ./types/

# Environment variables for JWT generation
# Prefer BACKEND_TOKEN_SECRET_FILE (Docker secrets pattern)
ENV BACKEND_TOKEN_SECRET_FILE=""
ENV BACKEND_TOKEN_SECRET=""
ENV NODE_ENV=development

# Expose mock service ports
# 4001: Mock Kratos
# 4002: Mock AuthHub
# 4003: Mock Backend (optional, for full mock mode)
EXPOSE 4001 4002 4003

# Non-root (bun image ships uid 1000)
USER bun

# Run the mock server
CMD ["bun", "x", "tsx", "mock-server.ts"]
