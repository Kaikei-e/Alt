{
	"name": "alt-frontend-sv",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:mock": "concurrently -k -n mock,vite \"bun run mock-server\" \"bun run dev --host\"",
		"dev:remote": "bun dev --host 0.0.0.0",
		"mock-server": "bunx tsx tests/e2e/infra/mock-server.ts",
		"build": "vite build",
		"preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsgo --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsgo --tsconfig ./tsconfig.json --watch",
		"lint": "biome lint --write",
		"format": "biome format --write",
		"test": "vitest run",
		"test:server": "vitest run --project=server",
		"test:client": "VITEST_BROWSER=true vitest run --project=client",
		"test:all": "VITEST_BROWSER=true vitest run",
		"test:watch": "vitest --watch",
		"test:e2e": "bun run build && npx playwright test --reporter=list",
		"test:e2e:ui": "npx playwright test --ui",
		"test:e2e:integration": "npx playwright test --project=integration --reporter=list",
		"test:coverage": "vitest run --coverage",
		"build:analyze": "ANALYZE=true vite build && echo 'Bundle report: stats.html'"
	},
	"dependencies": {
		"@bufbuild/protobuf": "^2.11.0",
		"@connectrpc/connect": "^2.1.1",
		"@connectrpc/connect-web": "^2.1.1",
		"@ory/client": "^1.22.35",
		"@tanstack/svelte-query": "^6.1.16",
		"@threlte/core": "^8.5.9",
		"@threlte/extras": "^9.14.6",
		"bits-ui": "^2.17.3",
		"chart.js": "^4.5.1",
		"clsx": "^2.1.1",
		"isomorphic-dompurify": "^3.9.0",
		"svelte-chartjs": "^4.0.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"three": "^0.184.0",
		"three-mesh-bvh": "^0.9.9",
		"valibot": "^1.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@bufbuild/protoc-gen-es": "^2.11.0",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.8.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.6.0",
		"@types/three": "^0.184.0",
		"@typescript/native-preview": "7.0.0-dev.20260421.2",
		"@vitest/browser": "^4.1.4",
		"@vitest/browser-playwright": "^4.1.4",
		"axe-core": "^4.11.3",
		"axe-playwright": "^2.2.2",
		"concurrently": "^9.2.1",
		"jsdom": "^29.0.2",
		"jsonwebtoken": "^9.0.3",
		"msw": "^2.13.4",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4",
		"vitest-browser-svelte": "^2.1.1"
	},
	"pnpm": {
		"overrides": {
			"cookie@<0.7.0": "^0.7.0"
		}
	}
}
