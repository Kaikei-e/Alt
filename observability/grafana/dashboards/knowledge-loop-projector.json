{
  "annotations": {
    "list": []
  },
  "description": "Knowledge Loop projector health (ADR-000852 / Wave 4). Counters live in knowledge-sovereign at /metrics on port 9501. Pair with observability/alerts/knowledge-loop-rules.yaml.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Surface bucket assignment rate, stacked by planner version. Once Wave 4-A / 4-B are landed and emitting, v2 should rise above v1 baseline.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Surface bucket rate (5m, by version × bucket)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (version, bucket) (rate(knowledge_loop_projector_surface_bucket_assigned_total[5m]))",
          "legendFormat": "{{version}} / {{bucket}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Change-summary writes split by redline_capable. Higher redline_capable=true ratio means upstream supersede events carry old + new excerpts (Wave 1).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Change summaries written (5m)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (redline_capable) (rate(knowledge_loop_projector_change_summary_written_total[5m]))",
          "legendFormat": "redline_capable={{redline_capable}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Cumulative event drops by reason. Any non-zero series during rollout points at a real wire-format drift — alert KnowledgeLoopEventDropSpike covers the rate side.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "Events dropped (cumulative, by reason)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (reason) (knowledge_loop_projector_event_dropped_total)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "F-001 cross-tenant isolation breach counter. Must stay at 0. The matching alert pages on the first non-zero increase.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "title": "Cross-user isolation violations (cumulative)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(knowledge_loop_projector_cross_user_isolation_violation_total)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Projector lag = max(knowledge_events.event_seq) − projector checkpoint. Sustained values >1000 trigger KnowledgeLoopProjectorLag.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "id": 5,
      "title": "Projector lag (events)",
      "type": "stat",
      "targets": [
        {
          "expr": "max(knowledge_events_max_event_seq) - max(knowledge_projection_checkpoint_last_event_seq{projector=\"knowledge-loop-projector\"})",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "ADR-000910: Act outcome events observed by the projector (Phase F §Δ1). Stacks by outcome enum so engaged / deep_engagement should dominate; rising no_engagement signals coverage gaps in the immediate outcome emitter.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 6,
      "title": "Act outcome rate (5m, by outcome)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (outcome) (rate(knowledge_loop_projector_act_outcome_emitted_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "ADR-000910: Lens mode switches per (from, to) pair. Use as a heatmap-style proxy for which cognitive modes the user traverses.",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 16
      },
      "id": 7,
      "title": "Lens mode switches (1h)",
      "type": "table",
      "targets": [
        {
          "expr": "sum by (from, to) (increase(knowledge_loop_projector_lens_mode_switched_total[1h]))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "ADR-000910: 7-day delta of dismiss_state transitions to internalized (knowledge graduation, ADR-000908 §Δ3). A rising number confirms the卒業 loop is closing.",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 16
      },
      "id": 8,
      "title": "Internalized this week",
      "type": "stat",
      "targets": [
        {
          "expr": "increase(knowledge_loop_projector_internalized_total[7d])",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "ADR-000910: Rate of cron-filled no_engagement outcomes. Rising rate signals the immediate outcome emitter (alt-backend view tracker) is missing engagement events.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 9,
      "title": "Outcome missing fill rate (1h)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(knowledge_loop_projector_outcome_missing_total[1h])",
          "legendFormat": "no_engagement / s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "PM-2026-045 action #5: SSE session lifecycle. started_total should track ended_total{reason=ctx_done} 1:1 in steady state. A growing gap means the catch-race or nginx buffering is back.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 10,
      "title": "SSE stream lifecycle (5m rate, by reason)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(alt_knowledge_loop_stream_started_total[5m]))",
          "legendFormat": "started",
          "refId": "A"
        },
        {
          "expr": "sum by (reason) (rate(alt_knowledge_loop_stream_ended_total[5m]))",
          "legendFormat": "ended / {{reason}}",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "PM-2026-045 action #4: JWT-expired share of stream terminations. Healthy value is near 0 with 30m TTL (ADR-000929). Climbing above ~5% means BACKEND_TOKEN_TTL × streamStaleTimeout drift.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "id": 11,
      "title": "Stream JWT-expired ratio (5m)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "expr": "knowledge_loop:stream_jwt_expired_ratio_5m",
          "legendFormat": "jwt_expired / started",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "PM-2026-045 action #5: upstream fetch failures inside an active stream session. Three consecutive failures escalate to ended{reason=upstream_error}; this panel shows the precursor signal.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "id": 12,
      "title": "Stream upstream fetch failures (5m rate)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(alt_knowledge_loop_stream_fetch_failed_total[5m])",
          "legendFormat": "fetch_failed / s",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": [
    "knowledge-loop",
    "projector",
    "wave-4"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Knowledge Loop Projector",
  "uid": "knowledge-loop-projector",
  "version": 1,
  "weekStart": ""
}
