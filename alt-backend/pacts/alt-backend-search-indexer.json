{
  "consumer": {
    "name": "alt-backend"
  },
  "interactions": [
    {
      "description": "an authenticated SearchArticles Connect-RPC call from alt-backend",
      "providerStates": [
        {
          "name": "a service token is configured and articles are indexed"
        }
      ],
      "request": {
        "body": {
          "limit": 20,
          "query": "LLM",
          "userId": "user-1"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.limit": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.query": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/services.search.v2.SearchService/SearchArticles"
      },
      "response": {
        "body": {
          "estimatedTotalHits": 1,
          "hits": [
            {
              "content": "body",
              "id": "article-1",
              "tags": [
                "ai"
              ],
              "title": "An LLM primer"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.estimatedTotalHits": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.hits": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.hits[*].content": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.hits[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.hits[*].tags": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.hits[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "an authenticated SearchRecaps by tag Connect-RPC call from alt-backend",
      "providerStates": [
        {
          "name": "a service token is configured and recap jobs are indexed under a tag"
        }
      ],
      "request": {
        "body": {
          "limit": 10,
          "tagName": "technology"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.limit": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.tagName": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/services.search.v2.SearchService/SearchRecaps"
      },
      "response": {
        "body": {
          "estimatedTotalHits": 1,
          "hits": [
            {
              "bullets": [
                "bullet"
              ],
              "executedAt": "2026-04-10T00:00:00Z",
              "genre": "technology",
              "jobId": "job-1",
              "summary": "weekly recap",
              "tags": [
                "technology"
              ],
              "topTerms": [
                "ai"
              ],
              "windowDays": 7
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.estimatedTotalHits": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.hits": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.hits[*].bullets": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.hits[*].executedAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.hits[*].genre": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.hits[*].jobId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.hits[*].summary": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.hits[*].tags": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.hits[*].topTerms": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.hits[*].windowDays": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.4.2"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "search-indexer"
  }
}