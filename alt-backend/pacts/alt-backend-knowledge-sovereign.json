      "description": "a GetTrailFootprints request for the user",
      "providerStates": [
        {
          "name": "a user with at least one footprint exists"
        }
      ],
      "request": {
        "body": {
          "limit": 20,
          "userId": "22222222-2222-2222-2222-222222222222"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.limit": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/services.sovereign.v1.KnowledgeSovereignService/GetTrailFootprints"
      },
      "response": {
        "body": {
          "footprints": [
            {
              "footprintKey": "open:article:1",
              "itemKey": "article:1",
              "occurredAt": "2026-06-10T09:12:00Z",
              "verb": "read"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.footprints": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.footprints[*].footprintKey": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.footprints[*].itemKey": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.footprints[*].occurredAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.footprints[*].verb": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
