              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.footprints[*].verb": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
