              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.footprints": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.footprints[*].footprintKey": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
