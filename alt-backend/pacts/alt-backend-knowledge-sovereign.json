                  "kind": "tag",
                  "refId": "rust"
                }
              ],
              "relationKind": "cluster",
              "why": "Joins a topic you follow."
            }
          ],
          "footprints": [
            {
              "footprintKey": "open:article:1",
              "itemKey": "article:1",
              "occurredAt": "2026-06-10T09:12:00Z",
