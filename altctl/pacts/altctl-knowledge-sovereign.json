{
  "consumer": {
    "name": "altctl"
  },
  "interactions": [
    {
      "description": "a latest snapshot query",
      "providerStates": [
        {
          "name": "at least one snapshot exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/admin/snapshots/latest"
      },
      "response": {
        "body": {
          "CreatedAt": "2026-04-23T00:00:00Z",
          "DedupesChecksum": "sha256:cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "EventSeqBoundary": 1,
          "ItemsChecksum": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "SnapshotID": "11111111-2222-3333-4444-555555555555",
          "VersionsChecksum": "sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.CreatedAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.DedupesChecksum": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^sha256:[0-9a-f]{64}$"
                }
              ]
            },
            "$.EventSeqBoundary": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.ItemsChecksum": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^sha256:[0-9a-f]{64}$"
                }
              ]
            },
            "$.SnapshotID": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[0-9a-f]{8}-([0-9a-f]{4}-){3}[0-9a-f]{12}$"
                }
              ]
            },
            "$.VersionsChecksum": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^sha256:[0-9a-f]{64}$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a retention dry-run request",
      "providerStates": [
        {
          "name": "retention policies are configured"
        }
      ],
      "request": {
        "body": {
          "dry_run": true
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.dry_run": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/admin/retention/run"
      },
      "response": {
        "body": {
          "actions": [
            {
              "action": "would_archive",
              "partition_name": "knowledge_events_y2025m01",
              "table": "knowledge_events"
            }
          ],
          "dry_run": true
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.actions": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.actions[*].action": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.actions[*].partition_name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.actions[*].table": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.dry_run": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a retention eligible query",
      "providerStates": [
        {
          "name": "retention policies are configured"
        }
      ],
