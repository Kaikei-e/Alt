    "@std/testing/mock": "jsr:@std/testing@^1.0.17/mock",
    "@opentelemetry/api": "npm:@opentelemetry/api@1.9.0",
    "@opentelemetry/api-logs": "npm:@opentelemetry/api-logs@0.212.0",
    "@opentelemetry/sdk-logs": "npm:@opentelemetry/sdk-logs@0.212.0",
