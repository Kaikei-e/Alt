# Atlas Migration Container for Alt RSS Reader Database
# Based on 2025 Kubernetes-native migration best practices
FROM arigaio/atlas:latest-alpine

# Connectivity is checked via busybox `nc` (already in arigaio/atlas:*-alpine)
# instead of pg_isready. The previous `apk add --no-cache postgresql-client`
# step was the sole network dependency at image build time and caused
# multi-hour hangs when dl-cdn.alpinelinux.org was slow / IPv6-only on the
# build host (observed 2026-04-30 on alt-deploy run 25143212120).
# A TCP open-port probe is sufficient: Atlas itself surfaces auth/db errors
# on `migrate apply`, so the pre-flight check only needs to verify the
# database listener is reachable.

# Create migration directory and set working directory
WORKDIR /migrations

# Copy all migration files from migrations directory (context is parent)
COPY migrations/ ./

# Create scripts directory for helper scripts
RUN mkdir -p /scripts

# Copy migration execution scripts from docker/scripts directory
COPY scripts/ /scripts/

# Set permissions
RUN chmod +x /scripts/*.sh

# Fix ownership for non-root user
RUN chown -R 1001:1001 /migrations /scripts

# Set default user (non-root for security)
USER 1001:1001

# Override Atlas entrypoint to use our scripts
ENTRYPOINT ["/scripts/migration.sh"]

# Default command runs migration status check
CMD ["status"]