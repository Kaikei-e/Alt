# ggml-org dropped Q4_K_M after the 2026-07-15 weight refresh; Q4_0 is the
# official 4-bit text GGUF (~4.59GB). Ollama tag gemma4-e4b-q4km is kept for
# consumer env compatibility (PM-2026-016).
FROM /tmp/gguf/gemma-4-E4B-it-Q4_0.gguf

TEMPLATE """{{- $system := "" }}
{{- range .Messages }}
{{- if eq .Role "system" }}
{{- if not $system }}{{ $system = .Content }}
{{- else }}{{ $system = printf "%s\n\n%s" $system .Content }}
{{- end }}
{{- continue }}
{{- else if eq .Role "user" }}<|turn>user
{{- if $system }}
{{ $system }}
{{- $system = "" }}
{{- end }}
{{- else if eq .Role "assistant" }}<|turn>model
{{- end }}
{{ .Content }}<turn|>
{{ end }}<|turn>model
"""

PARAMETER stop <turn|>
