{
  "consumer": {
    "name": "rag-orchestrator"
  },
  "interactions": [
    {
      "description": "a GET for the latest morning letter",
      "providerStates": [
        {
          "name": "a published morning letter exists for today"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/v1/morning/letters/latest"
      },
      "response": {
        "body": {
          "body": {
            "lead": "Today's key developments...",
            "sections": [
              {
                "bullets": [
                  "Story A"
                ],
                "key": "top3",
                "title": "Top Stories"
              }
            ]
          },
          "id": "letter-001",
          "target_date": "2026-04-15"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.body": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.body.lead": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.body.sections": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.body.sections[*].bullets": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.body.sections[*].key": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.body.sections[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.target_date": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a GET for the latest morning letter when none exists",
      "providerStates": [
        {
          "name": "no morning letter has been published yet"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/v1/morning/letters/latest"
      },
      "response": {
        "status": 404
      }
    },
    {
      "description": "a GET for the morning letter of 2026-04-14",
      "providerStates": [
        {
          "name": "a morning letter exists for 2026-04-14"
        }
      ],
      "request": {
        "matchingRules": {
          "path": {
            "combine": "AND",
            "matchers": [
              {
                "match": "regex",
                "regex": "/v1/morning/letters/\\d{4}-\\d{2}-\\d{2}"
              }
            ]
          }
        },
        "method": "GET",
        "path": "/v1/morning/letters/2026-04-14"
      },
      "response": {
        "body": {
          "body": {
            "lead": "Today's key developments...",
            "sections": [
              {
                "bullets": [
                  "Story A"
                ],
                "key": "top3",
                "title": "Top Stories"
              }
            ]
          },
          "id": "letter-001",
          "target_date": "2026-04-15"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.body": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.body.lead": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.body.sections": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.body.sections[*].bullets": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.body.sections[*].key": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.body.sections[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.target_date": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.4.2"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "recap-worker"
  }
}