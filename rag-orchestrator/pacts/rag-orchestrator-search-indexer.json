{
  "consumer": {
    "name": "rag-orchestrator"
  },
  "interactions": [
    {
      "description": "a /v1/search request from rag-orchestrator",
      "providerStates": [
        {
          "name": "search has indexed articles"
        }
      ],
      "request": {
        "matchingRules": {
          "query": {
            "q": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "GET",
        "path": "/v1/search",
        "query": {
          "q": [
            "LLM"
          ],
          "user_id": [
            "rag-orchestrator-system"
          ]
        }
      },
      "response": {
        "body": {
          "hits": [
            {
              "content": "Some content",
              "id": "article-1",
              "tags": [
                "ai"
              ],
              "title": "An LLM primer"
            }
          ],
          "query": "LLM"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.hits": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.hits[*].content": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.hits[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.hits[*].tags": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.hits[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.query": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
